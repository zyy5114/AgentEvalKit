{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentevalkit.dev/schemas/trace.schema.json",
  "title": "AgentEvalKit Execution Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "events"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "step_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
